          { "kind": "Property", "name": "DataContext", "type": "object", "access": "Public" }
        ]},
        { "name": "ViewModelBase", "role": "ViewModel", "isAbstract": true, "offsetX": 260, "offsetY": 0, "members": [
          { "kind": "Method", "name": "OnPropertyChanged", "returnType": "void", "access": "Protected", "parameters": [{ "name": "name", "type": "string" }], "generateStub": true }
        ]},
        { "name": "MainViewModel", "role": "ViewModel", "offsetX": 260, "offsetY": 140, "baseType": "ViewModelBase", "members": [
          { "kind": "Property", "name": "Title", "type": "string", "access": "Public" },
          { "kind": "Method", "name": "LoadCommand", "returnType": "void", "access": "Public", "generateStub": true }
        ]},
        { "name": "Model", "role": "Model", "offsetX": 520, "offsetY": 70, "members": [
          { "kind": "Method", "name": "Fetch", "returnType": "object", "access": "Public", "generateStub": true }
        ]}
      ],
      "relations": [
        { "from": "MainViewModel", "to": "ViewModelBase", "kind": "Inherits" },
        { "from": "MainViewModel", "to": "Model", "kind": "Uses" }
      ]
    },
    {
      "id": "singleton",
      "name": "Singleton",
      "category": "Creational",
      "description": "Single instance with global access.",
      "classes": [
        { "name": "Singleton", "role": "None", "offsetX": 0, "offsetY": 0, "members": [
          { "kind": "Field", "name": "_instance", "type": "Singleton", "access": "Private", "isStatic": true },
          { "kind": "Constructor", "name": "Singleton", "access": "Private" },
          { "kind": "Method", "name": "Instance", "returnType": "Singleton", "access": "Public", "isStatic": true, "generateStub": true }
        ]}
      ],
      "relations": []
    },
    {
      "id": "factory",
      "name": "Factory Method",
      "category": "Creational",
      "description": "Creator declares factory method; subclasses return concrete products.",
      "classes": [
        { "name": "IProduct", "role": "Interface", "isInterface": true, "offsetX": 0, "offsetY": 140, "members": [
          { "kind": "Method", "name": "Operation", "returnType": "void", "access": "Public", "isAbstract": true }
        ]},
        { "name": "Creator", "role": "Factory", "isAbstract": true, "offsetX": 0, "offsetY": 0, "members": [
          { "kind": "Method", "name": "CreateProduct", "returnType": "IProduct", "access": "Public", "isAbstract": true }
        ]},
        { "name": "ConcreteCreator", "role": "Factory", "offsetX": 260, "offsetY": 0, "baseType": "Creator", "members": [
          { "kind": "Method", "name": "CreateProduct", "returnType": "IProduct", "access": "Public", "generateStub": true }
        ]},
        { "name": "ConcreteProduct", "role": "Model", "offsetX": 260, "offsetY": 140, "implements": ["IProduct"], "members": [
          { "kind": "Method", "name": "Operation", "returnType": "void", "access": "Public", "generateStub": true }
        ]}
      ],
      "relations": [
        { "from": "ConcreteCreator", "to": "Creator", "kind": "Inherits" },
        { "from": "ConcreteProduct", "to": "IProduct", "kind": "Implements" }
      ]
    },
    {
      "id": "strategy",
      "name": "Strategy",
      "category": "Behavioral",
      "description": "Encapsulate interchangeable algorithms behind a common interface.",
