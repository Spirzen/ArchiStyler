        ]},
        { "name": "ConcreteStrategyA", "role": "Strategy", "offsetX": 0, "offsetY": 120, "implements": ["IStrategy"], "members": [
          { "kind": "Method", "name": "Execute", "returnType": "void", "access": "Public", "generateStub": true }
        ]},
        { "name": "Context", "role": "Service", "offsetX": 280, "offsetY": 40, "members": [
          { "kind": "Field", "name": "_strategy", "type": "IStrategy", "access": "Private" },
          { "kind": "Method", "name": "SetStrategy", "returnType": "void", "access": "Public", "parameters": [{ "name": "strategy", "type": "IStrategy" }] },
          { "kind": "Method", "name": "DoWork", "returnType": "void", "access": "Public", "generateStub": true }
        ]}
      ],
      "relations": [
        { "from": "ConcreteStrategyA", "to": "IStrategy", "kind": "Implements" },
        { "from": "Context", "to": "IStrategy", "kind": "Uses" }
      ]
    },
    {
      "id": "command",
      "name": "Command",
      "category": "Behavioral",
      "description": "Encapsulate requests as objects with execute/undo.",
