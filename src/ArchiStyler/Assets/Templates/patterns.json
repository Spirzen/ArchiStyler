          { "kind": "Method", "name": "Request", "returnType": "void", "access": "Public", "generateStub": true }
        ]}
      ],
      "relations": [
        { "from": "Adapter", "to": "ITarget", "kind": "Implements" },
        { "from": "Adapter", "to": "Adaptee", "kind": "Uses" }
      ]
    },
    {
      "id": "layered",
      "name": "Слои (Models / Data / Handlers)",
      "category": "Architectural",
      "description": "Классическая раскладка по папкам: модели, доступ к данным, обработчики.",
      "folders": [
        { "name": "Models", "segment": "Models", "offsetX": 0, "offsetY": 0, "width": 300, "height": 220 },
        { "name": "Data", "segment": "Data", "offsetX": 320, "offsetY": 0, "width": 300, "height": 220 },
        { "name": "Handlers", "segment": "Handlers", "offsetX": 160, "offsetY": 250, "width": 320, "height": 220 }
      ],
      "classes": [
        { "name": "Entity", "role": "Model", "folder": "Models", "offsetX": 24, "offsetY": 36, "members": [
          { "kind": "Property", "name": "Id", "type": "string", "access": "Public" }
        ]},
        { "name": "IRepository", "role": "Interface", "folder": "Data", "isInterface": true, "offsetX": 20, "offsetY": 30, "members": [
          { "kind": "Method", "name": "GetById", "returnType": "Entity", "access": "Public", "isAbstract": true }
        ]},
        { "name": "Repository", "role": "Repository", "folder": "Data", "offsetX": 20, "offsetY": 100, "implements": ["IRepository"], "members": [
          { "kind": "Method", "name": "GetById", "returnType": "Entity", "access": "Public", "generateStub": true }
        ]},
        { "name": "CreateOrderHandler", "role": "Service", "folder": "Handlers", "offsetX": 24, "offsetY": 40, "members": [
          { "kind": "Field", "name": "_repo", "type": "IRepository", "access": "Private" },
          { "kind": "Method", "name": "Handle", "returnType": "void", "access": "Public", "generateStub": true }
        ]}
      ],
      "relations": [
        { "from": "Repository", "to": "IRepository", "kind": "Implements" },
        { "from": "CreateOrderHandler", "to": "IRepository", "kind": "Uses" },
        { "from": "IRepository", "to": "Entity", "kind": "Uses" }
      ]
    }
  ]
}
