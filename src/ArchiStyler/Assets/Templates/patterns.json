        { "name": "ICommand", "role": "Command", "isInterface": true, "offsetX": 0, "offsetY": 0, "members": [
          { "kind": "Method", "name": "Execute", "returnType": "void", "access": "Public", "isAbstract": true },
          { "kind": "Method", "name": "Undo", "returnType": "void", "access": "Public", "isAbstract": true }
        ]},
        { "name": "ConcreteCommand", "role": "Command", "offsetX": 0, "offsetY": 130, "implements": ["ICommand"], "members": [
          { "kind": "Method", "name": "Execute", "returnType": "void", "access": "Public", "generateStub": true },
          { "kind": "Method", "name": "Undo", "returnType": "void", "access": "Public", "generateStub": true }
        ]},
        { "name": "Invoker", "role": "Handler", "offsetX": 280, "offsetY": 50, "members": [
          { "kind": "Method", "name": "Run", "returnType": "void", "access": "Public", "parameters": [{ "name": "command", "type": "ICommand" }], "generateStub": true }
        ]}
