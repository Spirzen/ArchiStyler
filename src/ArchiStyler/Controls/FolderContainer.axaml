<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiStyler.ViewModels"
             x:Class="ArchiStyler.Controls.FolderContainer"
             x:DataType="vm:FolderNodeViewModel"
             Width="{Binding Width}"
             Height="{Binding Height}"
             MinWidth="120"
             MinHeight="100">
  <Border x:Name="FolderBorder" CornerRadius="10" Padding="0"
          BorderBrush="{DynamicResource BrushNeonLavender}"
          BorderThickness="1.5"
          Background="#22000000">
    <Border.Styles>
      <Style Selector="Border#FolderBorder">
        <Setter Property="Opacity" Value="0.92"/>
      </Style>
      <Style Selector="Border#FolderBorder.selected">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushNeonCyan}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BoxShadow" Value="0 0 18 2 #55a8f0ff"/>
      </Style>
    </Border.Styles>
    <Grid RowDefinitions="Auto,*">
      <Border x:Name="TitleBar" Grid.Row="0" Padding="10,6" CornerRadius="10,10,0,0"
              Background="#33000000" Cursor="Hand">
        <StackPanel Spacing="2">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="📁" FontSize="14"/>
            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource BrushNeonLavender}"/>
          </StackPanel>
          <TextBlock Text="{Binding ExportSubtitle}" FontSize="10"
                     Foreground="{DynamicResource BrushMuted}" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Border>
      <Border Grid.Row="1" Margin="8" CornerRadius="6"
              BorderBrush="{DynamicResource BrushBorder}"
              BorderThickness="1"
              Background="#11000000">
        <TextBlock Text="{Binding PathSubtitle}" FontSize="10"
                   Foreground="{DynamicResource BrushMuted}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.7"/>
      </Border>
    </Grid>
  </Border>
</UserControl>
